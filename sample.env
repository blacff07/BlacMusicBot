# ==============================================================================
# sample.env — BlacMusic Bot Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains sensitive credentials.
#
# Get values from:
#   API_ID / API_HASH  → https://my.telegram.org/apps
#   BOT_TOKEN          → @BotFather on Telegram
#   MONGO_DB_URI       → https://cloud.mongodb.com (free tier is fine)
#   OWNER_ID           → @userinfobot on Telegram
#   LOGGER_ID          → Create a private group, add bot as admin, get chat ID
#   STRING_SESSION     → @StringFatherBot on Telegram (Pyrogram session)
# ==============================================================================


# ── REQUIRED ──────────────────────────────────────────────────────────────────

API_ID=
API_HASH=
BOT_TOKEN=
MONGO_DB_URI=
OWNER_ID=
LOGGER_ID=
STRING_SESSION=


# ── BRANDING (optional — safe defaults used if not set) ───────────────────────

# BOT_NAME=˹ʙʟᴀᴄ ᴍᴜꜱɪᴄ˼
# BOT_ABOUT=ꜱᴛᴜᴅɪᴏ-ǫᴜᴀʟɪᴛʏ ᴍᴜꜱɪᴄ ꜱᴛʀᴇᴀᴍɪɴɢ ꜰᴏʀ ᴛᴇʟᴇɢʀᴀᴍ
# SOURCE_URL=https://github.com/yourusername/BlacMusicBot


# ── SUPPORT LINKS (optional) ──────────────────────────────────────────────────

# SUPPORT_CHANNEL=https://t.me/yourchannel
# SUPPORT_CHAT=https://t.me/yoursupportgroup


# ── CUSTOM IMAGES (optional — defaults used if not set) ───────────────────────

# START_IMG=https://files.catbox.moe/7jihmf.png
# PING_IMG=https://files.catbox.moe/djilyq.png
# RADIO_IMG=https://files.catbox.moe/t03fzk.png
# DEFAULT_THUMB=https://files.catbox.moe/kgrs8f.png


# ── EXTRA ASSISTANT SESSIONS (optional — for serving more groups) ─────────────

# STRING_SESSION2=
# STRING_SESSION3=


# ── LIMITS (optional) ─────────────────────────────────────────────────────────

# DURATION_LIMIT=300       # Max track duration in minutes (default: 300)
# QUEUE_LIMIT=30           # Max tracks in queue per group (default: 30)
# PLAYLIST_LIMIT=20        # Max tracks imported from a playlist (default: 20)


# ── FEATURE FLAGS (optional) ──────────────────────────────────────────────────

# AUTO_END=False           # End stream when queue is empty
# AUTO_LEAVE=False         # Leave voice chat when no one is listening
# THUMB_GEN=True           # Generate custom Now Playing thumbnails
# VIDEO_PLAY=False         # Enable /vplay command for video streaming
# VIDEO_MAX_HEIGHT=1080    # Max video resolution for /vplay (480–2160)


# ── YOUTUBE COOKIES (optional — needed for age-restricted videos) ─────────────

# COOKIE_URL=https://pastebin.com/raw/xxxxxxxx


# ── MODERATION (optional) ─────────────────────────────────────────────────────

# EXCLUDED_CHATS=-100123456,-100789012    # Chat IDs assistants never auto-leave
# EXCLUDED_USERNAMES=user1 user2          # Exclude from admin mention lists